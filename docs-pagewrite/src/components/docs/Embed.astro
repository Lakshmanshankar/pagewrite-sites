---
interface Props {
  platform: 'youtube' | 'codepen' | 'loom' | 'stackblitz';
  id: string;
  title?: string;
  author?: string;
}

const { platform, id, title = 'Embed Player', author } = Astro.props;

let embedUrl = '';
let aspectRatio = 'aspect-video';

if (platform === 'youtube') {
  embedUrl = `https://www.youtube.com/embed/${id}?rel=0`;
  aspectRatio = 'aspect-video';
} else if (platform === 'codepen') {
  embedUrl = `https://codepen.io/${author || 'anon'}/embed/${id}?default-tab=result&theme-id=dark`;
  aspectRatio = 'h-[450px] w-full';
} else if (platform === 'loom') {
  embedUrl = `https://www.loom.com/embed/${id}`;
  aspectRatio = 'aspect-video';
} else if (platform === 'stackblitz') {
  embedUrl = `https://stackblitz.com/edit/${id}?embed=1&theme=dark`;
  aspectRatio = 'h-[500px] w-full';
}
---
<div class="embed-container my-6 border border-zinc-800 rounded-xl overflow-hidden bg-zinc-950/40 shadow-lg">
  {embedUrl ? (
    <iframe
      src={embedUrl}
      title={title}
      class={`w-full border-0 ${aspectRatio}`}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
      loading="lazy"
    ></iframe>
  ) : (
    <div class="p-6 text-center text-sm text-zinc-500 font-mono">
      Unsupported embed platform: {platform}
    </div>
  )}
</div>
