---
import { Code } from 'astro:components';

interface Tab {
  label: string;
  code: string;
  lang?: any;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
const uniqueId = `codetabs-${Math.random().toString(36).substring(2, 9)}`;
---
<div class="code-tabs border border-zinc-800 rounded-xl overflow-hidden bg-zinc-950/60 backdrop-blur-sm my-6" id={uniqueId}>
  {/* Tab Headers */}
  <div class="flex items-center justify-between border-b border-zinc-800 bg-zinc-900/40 px-4 py-2">
    <div class="flex space-x-1" role="tablist">
      {tabs.map((tab, idx) => (
        <button
          role="tab"
          aria-selected={idx === 0 ? "true" : "false"}
          data-tab={idx}
          class={`px-3 py-1.5 text-xs font-medium rounded-md transition-all cursor-pointer ${
            idx === 0
              ? "bg-zinc-800 text-zinc-100 shadow-sm"
              : "text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40"
          }`}
        >
          {tab.label}
        </button>
      ))}
    </div>
    {/* Copy button */}
    <button 
      class="copy-btn text-zinc-500 hover:text-zinc-300 p-1.5 rounded-md hover:bg-zinc-800/50 transition-colors cursor-pointer"
      aria-label="Copy code"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon hidden text-emerald-500"><polyline points="20 6 9 17 4 12"/></svg>
    </button>
  </div>

  {/* Tab Contents */}
  <div class="code-panels">
    {tabs.map((tab, idx) => (
      <div
        role="tabpanel"
        data-panel={idx}
        class={`p-4 overflow-x-auto text-sm font-mono ${idx === 0 ? "" : "hidden"}`}
      >
        <Code code={tab.code} lang={tab.lang || 'bash'} theme="github-dark" />
      </div>
    ))}
  </div>
</div>

<script define:vars={{ uniqueId, tabs }}>
  const container = document.getElementById(uniqueId);
  if (container) {
    const buttons = container.querySelectorAll('[role="tab"]');
    const panels = container.querySelectorAll('[role="tabpanel"]');
    const copyBtn = container.querySelector('.copy-btn');
    const copyIcon = container.querySelector('.copy-icon');
    const checkIcon = container.querySelector('.check-icon');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetIdx = btn.getAttribute('data-tab');
        
        buttons.forEach((b) => {
          b.setAttribute('aria-selected', 'false');
          b.className = 'px-3 py-1.5 text-xs font-medium rounded-md transition-all cursor-pointer text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/40';
        });
        
        btn.setAttribute('aria-selected', 'true');
        btn.className = 'px-3 py-1.5 text-xs font-medium rounded-md transition-all cursor-pointer bg-zinc-800 text-zinc-100 shadow-sm';
        
        panels.forEach((panel) => {
          if (panel.getAttribute('data-panel') === targetIdx) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const activeTabIdx = Array.from(buttons).find(b => b.getAttribute('aria-selected') === 'true')?.getAttribute('data-tab') || '0';
        const codeToCopy = tabs[parseInt(activeTabIdx)]?.code || '';
        
        try {
          await navigator.clipboard.writeText(codeToCopy);
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
          setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });
    }
  }
</script>

<style is:global>
  /* Override default shiki background and paddings for seamless integration */
  .code-tabs pre.astro-code {
    background-color: transparent !important;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
  }
</style>
