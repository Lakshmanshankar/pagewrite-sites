---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings = [] } = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth == 1 || h.depth === 2 || h.depth === 3);
---
<nav class="toc-container hidden xl:block w-72 shrink-0 py-6 pl-2 pr-4 space-y-3.5 sticky top-14 self-start max-h-[calc(100vh-3.5rem)] overflow-y-auto">
  {filteredHeadings.length > 0 && (
    <>
      <h5 class="text-[10px] font-bold text-text-muted uppercase tracking-wider pl-1">
        On this page
      </h5>
      <ul class="space-y-2.5 text-sm text-text-muted border-l border-border-line" id="toc-list">
        {filteredHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              data-slug={heading.slug}
              class={`toc-link block py-0.5 border-l -ml-[1px] border-transparent hover:text-text-title transition-all leading-normal ${heading.depth === 3 ? "pl-6" : "pl-3"}`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </>
  )}
</nav>

<script>
  function initTOC() {
    // Dynamic Scroll Spy using IntersectionObserver
    const tocLinks = document.querySelectorAll('.toc-link');
    const headings = Array.from(document.querySelectorAll('article h2, article h3'));

    if (tocLinks.length > 0 && headings.length > 0) {
      const observerOptions = {
        root: null, // viewport
        rootMargin: '-80px 0px -60% 0px', // check headings in top/middle section
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            if (!id) return;
            
            tocLinks.forEach((link) => {
              const slug = link.getAttribute('data-slug');
              if (slug === id) {
                link.classList.add('text-primary-400', 'border-primary-500', 'font-medium');
                link.classList.remove('text-text-muted', 'border-transparent');
              } else {
                link.classList.remove('text-primary-400', 'border-primary-500', 'font-medium');
                link.classList.add('text-text-muted', 'border-transparent');
              }
            });
          }
        });
      }, observerOptions);

      headings.forEach((heading) => observer.observe(heading));
    }
  }

  // Initialize on load
  initTOC();
</script>
