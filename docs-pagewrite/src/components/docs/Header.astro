---
interface Props {
  activeTab?: 'docs' | 'showcase' | 'api' | 'home';
}

const { activeTab = 'home' } = Astro.props;
import lightLogo from '../../assets/pagewrite.svg';
import darkLogo from '../../assets/pagewrite-dark.svg';
---
<header class="md:hidden fixed top-0 left-0 right-0 z-40 border-b border-border-line bg-bg-sidebar/70 backdrop-blur-md">
  <div class="px-4 h-14 flex items-center justify-between">
    
    {/* Left: Brand Logo */}
    <a href="/" class="flex items-center group">
      <img src={lightLogo.src} alt="Pagewrite" class="h-7 w-auto light-logo" />
      <img src={darkLogo.src} alt="Pagewrite" class="h-7 w-auto dark-logo" />
    </a>

    {/* Mobile drawer trigger */}
    <button
      id="mobile-menu-toggle"
      class="flex items-center justify-center p-1.5 text-text-muted hover:text-text-title hover:bg-bg-card border border-border-line rounded-lg transition-colors cursor-pointer"
      aria-label="Toggle navigation menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hamburger-icon"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="close-icon hidden"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
    </button>
  </div>
</header>

<script>
  // Use event delegation to handle clicks, which survives DOM replacements and JS navigations
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    
    // Handle hamburger toggle
    const toggleBtn = target.closest('#mobile-menu-toggle');
    if (toggleBtn) {
      const hamburgerIcon = toggleBtn.querySelector('.hamburger-icon');
      const closeIcon = toggleBtn.querySelector('.close-icon');
      
      const isSidebarOpen = document.documentElement.classList.toggle('sidebar-open');
      if (isSidebarOpen) {
        hamburgerIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        hamburgerIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        document.body.style.overflow = '';
      }
      return;
    }

    // Handle clicks on sidebar links (close drawer on mobile)
    const sidebarLink = target.closest('.sidebar-drawer a');
    if (sidebarLink && window.innerWidth < 768) {
      document.documentElement.classList.remove('sidebar-open');
      const btn = document.getElementById('mobile-menu-toggle');
      if (btn) {
        btn.querySelector('.hamburger-icon')?.classList.remove('hidden');
        btn.querySelector('.close-icon')?.classList.add('hidden');
      }
      document.body.style.overflow = '';
    }
  });

  // Close sidebar drawer on resize to larger screens
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) {
      document.documentElement.classList.remove('sidebar-open');
      const btn = document.getElementById('mobile-menu-toggle');
      if (btn) {
        btn.querySelector('.hamburger-icon')?.classList.remove('hidden');
        btn.querySelector('.close-icon')?.classList.add('hidden');
      }
      document.body.style.overflow = '';
    }
  });
</script>
