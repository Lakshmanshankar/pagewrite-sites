---
import { getCollection } from 'astro:content';
import pagemap from '../../content/docs/pagemap.json';
import SidebarNode from './SidebarNode.astro';
import Search from './Search.astro';
import lightLogo from '../../assets/pagewrite.svg';
import darkLogo from '../../assets/pagewrite-dark.svg';

interface Props {
  activeSlug?: string;
}

const { activeSlug } = Astro.props;

// Fetch all documents to match with pagemap nodes
const docs = await getCollection('docs');

// Group docs by frontmatter id / pageId and by file path slug as fallback
const docMap = new Map<string, typeof docs[0]>();
docs.forEach((doc) => {
  const docId = doc.data.id || doc.data.pageId;
  if (docId) {
    docMap.set(docId, doc);
  }
  // Fallback by slug/file path
  docMap.set(doc.id, doc);
});
---
<aside class="sidebar-drawer flex flex-col fixed md:sticky top-0 left-0 h-screen z-30 w-[260px] border-r border-border-line bg-bg-page pt-4 pb-4 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out shrink-0">
  <div class="flex flex-col h-full pl-4 overflow-hidden">
    {/* Brand Logo */}
    <a href="/" class="flex items-center group mb-6 shrink-0">
      <img src={lightLogo.src} alt="Pagewrite" class="h-7 w-auto light-logo" />
      <img src={darkLogo.src} alt="Pagewrite" class="h-7 w-auto dark-logo" />
    </a>

    {/* Search */}
    <div class="mb-6 shrink-0">
      <Search />
    </div>

    {/* Navigation */}
    <nav class="flex-1 space-y-4 overflow-y-auto min-h-0 pr-2 pb-2">
      <div class="text-xs font-semibold text-text-muted mb-2 uppercase tracking-wider">Guide</div>
      <ul class="space-y-0.5">
        <SidebarNode nodes={pagemap} activeSlug={activeSlug} docMap={docMap} />
      </ul>
    </nav>

    {/* Bottom Fixed Links */}
    <div class="pt-4 mt-4 border-t border-border-line flex items-center justify-between text-text-muted shrink-0">
      <a 
        href="https://github.com/lakshmanshankar/pagewrite-astro"
        target="_blank" 
        rel="noopener noreferrer"
        class="flex items-center justify-center p-1.5 hover:text-text-title hover:bg-bg-card rounded-lg transition-colors cursor-pointer"
        aria-label="GitHub Repository"
      >
        <svg xmlns="http://www.w3.org/2050/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>

      <button
        id="theme-toggle-sidebar"
        class="flex items-center justify-center p-1.5 hover:text-text-title hover:bg-bg-card rounded-lg transition-colors cursor-pointer mr-2"
        aria-label="Toggle theme mode"
      >
        {/* Sun icon (visible in dark mode) */}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sun-icon"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        {/* Moon icon (visible in light mode) */}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="moon-icon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>
    </div>
  </div>
</aside>

<script>
  // Theme Toggle Logic for sidebar using event delegation to survive View Transitions
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('#theme-toggle-sidebar')) {
      const isLight = document.documentElement.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
    }
  });
</script>

<style>
  @media (max-width: 767px) {
    :global(html.sidebar-open) .sidebar-drawer {
      transform: translateX(0) !important;
      translate: 0 !important;
    }
  }
</style>
