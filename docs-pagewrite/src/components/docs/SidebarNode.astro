---
interface PageNode {
  id: string;
  title: string;
  slug: string;
  children?: PageNode[];
}

interface Props {
  nodes: PageNode[];
  activeSlug?: string;
  docMap: Map<string, any>;
  depth?: number;
}

const { nodes, activeSlug, docMap, depth = 0 } = Astro.props;

function capitalize(str: string): string {
  if (!str) return str;
  return str.charAt(0).toUpperCase() + str.slice(1);
}

function isNodeActive(node: PageNode, currentSlug?: string): boolean {
  if (!currentSlug) return false;
  return node.slug === currentSlug;
}

function hasActiveDescendant(node: PageNode, currentSlug?: string): boolean {
  if (!node.children || !currentSlug) return false;
  return node.children.some((child) => {
    if (isNodeActive(child, currentSlug)) return true;
    return hasActiveDescendant(child, currentSlug);
  });
}
---

{nodes.map((node) => {
  const hasChildren = node.children && node.children.length > 0;
  
  if (hasChildren) {
    const isOpen = hasActiveDescendant(node, activeSlug);
    const folderTitle = capitalize(node.title);
    
    return (
      <li class="list-none">
        <details class="group" open={isOpen}>
          <summary class="flex items-center justify-between px-2 py-1 text-sm rounded-md hover:bg-bg-card cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <span class="flex items-center gap-1">
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                viewBox="0 0 24 24" 
                fill="none" 
                stroke="currentColor" 
                stroke-width="2.5" 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                class="w-3 h-3 text-text-muted transition-transform duration-200 group-open:rotate-90"
              >
                <path d="m9 18 6-6-6-6"/>
              </svg>
              <span>{folderTitle}</span>
            </span>
          </summary>
          <ul class="pl-2 border-l border-border-line/45 ml-3 mt-0.5 space-y-0.5">
            <Astro.self 
              nodes={node.children!} 
              activeSlug={activeSlug} 
              docMap={docMap} 
              depth={depth + 1} 
            />
          </ul>
        </details>
      </li>
    );
  } else {
    const doc = docMap.get(node.id);
    const isSelf = node.slug === activeSlug;
    const title = node.title === 'index' ? 'Overview' : (doc?.data?.title || node.title);
    const href = node.slug === 'index' ? '/docs' : `/docs/${node.slug.endsWith('/index') ? node.slug.slice(0, -6) : node.slug}`;
    
    return (
      <li class="list-none">
        <a
          href={href}
          class={`flex items-center px-2 py-1 text-sm rounded-md border transition-all ${
            isSelf
              ? "bg-primary-500/5 text-primary-500 border-primary-500/10"
              : "border-transparent hover:bg-bg-card"
          }`}
        >
          {title}
        </a>
      </li>
    );
  }
})}
