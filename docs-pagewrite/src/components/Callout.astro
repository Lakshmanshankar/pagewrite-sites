---
import { Info, AlertCircle, CheckCircle2, AlertTriangle, CircleX, Lightbulb, MessageSquareText } from "@lucide/astro";

type CalloutVariant = "info" | "note" | "success" | "warning" | "error" | "tip" | "custom";

interface Props {
  variant?: CalloutVariant;
  title?: string;
  class?: string;
}

const { variant = "info", title, class: className = "" } = Astro.props;

const VARIANTS = {
  info: {
    class: "variant-info",
    icon: Info,
  },
  note: {
    class: "variant-note",
    icon: MessageSquareText,
  },
  success: {
    class: "variant-success",
    icon: CheckCircle2,
  },
  warning: {
    class: "variant-warning",
    icon: AlertTriangle,
  },
  error: {
    class: "variant-error",
    icon: CircleX,
  },
  tip: {
    class: "variant-tip",
    icon: Lightbulb,
  },
  custom: {
    class: "variant-custom",
    icon: AlertCircle,
  },
} satisfies Record<CalloutVariant, { class: string; icon: typeof Info }>;

const { class: variantClass, icon: Icon } = VARIANTS[variant];
---

<aside class={`callout ${variantClass} ${className}`.trim()}>
  <div class="callout-icon-wrap" aria-hidden="true">
    <Icon size={18} class="callout-icon" />
  </div>

  <div class="callout-content">
    {title && <p class="callout-title">{title}</p>}
    <div class="callout-body">
      <slot />
    </div>
  </div>
</aside>

<style>
  .callout {
    --callout-accent: #1f6feb;
    --callout-border: rgba(31, 111, 235, 0.22);
    --callout-bg: rgba(31, 111, 235, 0.08);
    --callout-icon-bg: rgba(31, 111, 235, 0.12);
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.85rem;
    margin: 1.25rem 0;
    padding: 0.95rem 1rem;
    border: 1px solid var(--callout-border);
    border-radius: 0.9rem;
    background: var(--callout-bg);
  }

  .variant-info {
    --callout-accent: #1f6feb;
    --callout-border: rgba(31, 111, 235, 0.22);
    --callout-bg: rgba(31, 111, 235, 0.08);
    --callout-icon-bg: rgba(31, 111, 235, 0.12);
  }

  .variant-note,
  .variant-custom {
    --callout-accent: #44546f;
    --callout-border: rgba(68, 84, 111, 0.2);
    --callout-bg: rgba(68, 84, 111, 0.08);
    --callout-icon-bg: rgba(68, 84, 111, 0.12);
  }

  .variant-success {
    --callout-accent: #216e4e;
    --callout-border: rgba(33, 110, 78, 0.24);
    --callout-bg: rgba(33, 110, 78, 0.08);
    --callout-icon-bg: rgba(33, 110, 78, 0.12);
  }

  .variant-warning {
    --callout-accent: #a15c00;
    --callout-border: rgba(161, 92, 0, 0.24);
    --callout-bg: rgba(161, 92, 0, 0.08);
    --callout-icon-bg: rgba(161, 92, 0, 0.12);
  }

  .variant-error {
    --callout-accent: #c9372c;
    --callout-border: rgba(201, 55, 44, 0.24);
    --callout-bg: rgba(201, 55, 44, 0.08);
    --callout-icon-bg: rgba(201, 55, 44, 0.12);
  }

  .variant-tip {
    --callout-accent: #7f5af0;
    --callout-border: rgba(127, 90, 240, 0.22);
    --callout-bg: rgba(127, 90, 240, 0.08);
    --callout-icon-bg: rgba(127, 90, 240, 0.12);
  }

  :global(html:not(.light)) .callout {
    --callout-border: color-mix(in srgb, var(--callout-accent) 30%, rgba(255, 255, 255, 0.08));
    --callout-bg: color-mix(in srgb, var(--callout-accent) 10%, rgba(255, 255, 255, 0.03));
    --callout-icon-bg: color-mix(in srgb, var(--callout-accent) 16%, rgba(255, 255, 255, 0.05));
  }

  .callout-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    margin-top: 0.05rem;
    border-radius: 999px;
    background: var(--callout-icon-bg);
    color: var(--callout-accent);
    flex-shrink: 0;
  }

  .callout-icon {
    display: block;
  }

  .callout-content {
    min-width: 0;
  }

  .callout-title {
    margin: 0 0 0.3rem;
    color: var(--text-main);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .callout-body {
    color: var(--text-soft);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .callout-body :global(p) {
    margin: 0.25rem 0;
  }

  .callout-body :global(p:first-child) {
    margin-top: 0;
  }

  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout-body :global(strong) {
    color: var(--text-main);
    font-weight: 700;
  }

  .callout-body :global(code) {
    color: var(--text-main);
  }
</style>
