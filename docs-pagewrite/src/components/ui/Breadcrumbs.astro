---
interface Props {
  segments: { name: string; url?: string }[];
}

const { segments } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center space-x-2 text-sm text-text-muted">
    {segments.map((segment, index) => (
      <li class="flex items-center space-x-2">
        {segment.url ? (
          <a 
            href={segment.url} 
            class="hover:text-text-title transition-interactive truncate max-w-[150px] md:max-w-[200px]"
          >
            {segment.name}
          </a>
        ) : (
          <span class="text-text-main font-medium truncate max-w-[150px] md:max-w-[200px]" aria-current="page">
            {segment.name}
          </span>
        )}
        
        {index < segments.length - 1 && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50 shrink-0"><path d="m9 18 6-6-6-6"/></svg>
        )}
      </li>
    ))}
  </ol>
</nav>
