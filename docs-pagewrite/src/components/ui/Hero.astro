---
interface Props {
  title: string;
  description: string;
  primaryAction?: {
    text: string;
    href: string;
  };
  secondaryAction?: {
    text: string;
    href: string;
  };
}

const { title, description, primaryAction, secondaryAction } = Astro.props;
---

<section class="py-16 md:py-24 max-w-4xl animate-slide-up">
  <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-text-title mb-6 leading-tight">
    {title}
  </h1>
  
  <p class="text-lg md:text-xl text-text-muted max-w-2xl mb-10 leading-relaxed">
    {description}
  </p>
  
  <div class="flex flex-wrap items-center gap-4">
    {primaryAction && (
      <a 
        href={primaryAction.href}
        class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-primary-500 text-bg-page font-medium hover:bg-primary-500/90 hover:scale-[1.02] transition-interactive shadow-sm"
      >
        {primaryAction.text}
      </a>
    )}
    
    {secondaryAction && (
      <a 
        href={secondaryAction.href}
        class="inline-flex items-center justify-center px-6 py-3 rounded-full border border-border-line bg-transparent text-text-main font-medium hover:bg-bg-card hover:border-border-line transition-interactive"
      >
        {secondaryAction.text}
      </a>
    )}
  </div>
</section>
