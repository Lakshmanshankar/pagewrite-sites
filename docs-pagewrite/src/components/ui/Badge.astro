---
interface Props {
  variant?: 'default' | 'primary' | 'outline';
}

const { variant = 'default' } = Astro.props;

const variants = {
  default: 'bg-bg-page text-text-main border-border-card',
  primary: 'bg-primary-500 text-bg-page border-transparent font-medium',
  outline: 'bg-transparent text-text-muted border-border-line',
};
---

<span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs border ${variants[variant]}`}>
  <slot />
</span>
