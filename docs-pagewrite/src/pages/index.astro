---
import Layout from '../layouts/Layout.astro';
import Card from '../components/docs/Card.astro';
---

<Layout title="Pagewrite | Visual Docs CMS for Astro" activeTab="home">
  {/* Hero Section */}
  <section class="relative overflow-hidden py-24 sm:py-32 border-b border-border-line bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary-950/20 via-bg-page to-bg-page">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-6">
      
      {/* Visual Sync Badge */}
      <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full border border-primary-500/25 bg-primary-950/20 text-primary-400 text-[10px] font-semibold tracking-wide uppercase shadow-[0_0_15px_rgba(16,185,129,0.05)] mx-auto animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mr-1"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
        CMS Content Sync Connected
      </div>

      <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-text-title max-w-3xl mx-auto leading-tight sm:leading-none">
        Visual editing for <span class="bg-gradient-to-r from-primary-400 to-cyan-400 bg-clip-text text-transparent">developer docs</span>.
      </h1>
      
      <p class="text-sm sm:text-base text-text-muted max-w-2xl mx-auto leading-relaxed">
        Write structured content visually in Pagewrite, use advanced editor nodes, and sync everything into your Astro file system before build. Keep your Git workflow, static performance, and styling control.
      </p>

      {/* Action Buttons */}
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <a
          href="/docs/getting-started"
          class="w-full sm:w-auto px-6 py-2.5 rounded-lg text-xs font-semibold bg-primary-500 text-bg-page hover:bg-primary-400 transition-all shadow-lg shadow-primary-500/10 cursor-pointer text-center"
        >
          Read the Docs
        </a>
      </div>

      {/* Copy-paste Install Command */}
      <div class="max-w-md mx-auto pt-6">
        <div class="flex items-center justify-between px-4 py-2 bg-bg-card border border-border-line rounded-lg text-xs font-mono text-text-muted shadow-inner">
          <span class="text-text-muted/70 select-none">pnpm install @lakshmanshankar/pagwrite-astro</span>
          <button 
            id="copy-install-btn" 
            class="text-text-muted hover:text-text-title transition-colors p-1 cursor-pointer"
            aria-label="Copy install command"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-ic"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            <svg xmlns="http://www.w3.org/2050/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-ic hidden text-primary-400"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>

    </div>
  </section>

  {/* Feature Grid */}
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center space-y-3 mb-12">
      <h2 class="text-xl sm:text-2xl font-bold text-text-title tracking-tight">
        Why build documentation templates with Pagewrite?
      </h2>
      <p class="text-xs sm:text-sm text-text-muted max-w-xl mx-auto">
        Get the developer autonomy of a local Markdown setup mixed with the rich writing workspace of a visual editor.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      
      <Card
        title="100% Static Performance"
        description="Synced content compiles to raw HTML. No databases, APIs, or CMS javascript loaded on the client side."
        href="/docs/getting-started"
        icon={`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`}
      />

      <Card
        title="Sync Before Build"
        description="The sync client fetches visual pages and outputs standard markdown before local development or deployment runs."
        href="/docs/content-sync"
        icon={`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>`}
      />

      <Card
        title="Advanced Editor Nodes"
        description="Supports visual tabs, responsive video players, custom warnings, and multi-column visual grids out of the box."
        href="/docs/advanced-nodes"
        icon={`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>`}
      />

      <Card
        title="Image Optimization"
        description="Visual assets uploaded inside the CMS are automatically resized, webp-ified, and synced locally to public folders."
        href="/docs/configuration"
        icon={`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>`}
      />

      <Card
        title="Code Switcher Tabs"
        description="Display installation scripts or code syntax in multiple languages inside structured visual tab groupings."
        href="/docs/code-tabs"
        icon={`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="13" y2="13"/></svg>`}
      />

    </div>
  </section>

  {/* Client copy script */}
  <script>
    const btn = document.getElementById('copy-install-btn');
    const copyIc = btn?.querySelector('.copy-ic');
    const checkIc = btn?.querySelector('.check-ic');
    
    btn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('npm install @lakshmanshankar/pagwrite-astro');
        copyIc?.classList.add('hidden');
        checkIc?.classList.remove('hidden');
        setTimeout(() => {
          copyIc?.classList.remove('hidden');
          checkIc?.classList.add('hidden');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy text', err);
      }
    });
  </script>
</Layout>
