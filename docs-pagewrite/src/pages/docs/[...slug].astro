---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CodeTabs from '../../components/docs/CodeTabs.astro';
import Embed from '../../components/docs/Embed.astro';
import ImageGallery from '../../components/docs/ImageGallery.astro';
import NodeVariant from '../../components/docs/NodeVariant.astro';
import Card from '../../components/docs/Card.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const paths =  docs.map((doc) => {
    let slug: string | undefined = doc.id;
    if (slug === 'index') {
      slug = undefined;
    } else if (slug.endsWith('/index')) {
      slug = slug.slice(0, -6);
    }
    return {
      params: { slug },
      props: { doc },
    };
  });
  return paths;
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);
---

<Layout
  title={doc.data.title}
  description={doc.data.description}
  isDocsPage={true}
  activeSlug={doc.id}
  headings={headings}
  activeTab="docs"
>
  <Content components={{ CodeTabs, Embed, ImageGallery, NodeVariant, Card }} />
</Layout>
